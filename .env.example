# Gmail credentials
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Comma-separated list of your own email addresses and aliases
# Used to filter Sent folder: only emails where From matches one of these are counted as "sent by you"
GMAIL_ALIASES=your.email@gmail.com,alias@yourdomain.com

# Google AI API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...

# Optional: override default model
# GEMINI_MODEL=gemini-2.5-flash

# Pfad zum mbsync-Maildir (All-Mail-Ordner) im Container.
# Wird von 'fetch' als Default genutzt wenn --maildir nicht explizit angegeben.
# Leer lassen um direkt per IMAP zu fetchen (Legacy-Modus).
MAILDIR_PATH=/data/maildir/All Mail
